# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/kdp_automation

# ── Anthropic (Claude vision) ─────────────────────────────────────────────────
# When running on Replit these are injected automatically via the Anthropic
# integration. Set them manually when running locally.
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...

# ── Session security ──────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── Local Chrome CDP connection (strongly recommended for local use) ──────────
#
# Start Chrome with remote debugging enabled, then set this variable so
# Playwright connects to your existing browser session instead of launching
# a new headless one.  This gives the automation access to your live
# Amazon KDP login automatically.
#
# macOS:
#   /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome \
#     --remote-debugging-port=9222 \
#     --user-data-dir="$HOME/chrome-kdp-profile"
#
# Windows (run in cmd as administrator):
#   "C:\Program Files\Google\Chrome\Application\chrome.exe" ^
#     --remote-debugging-port=9222 ^
#     --user-data-dir="%USERPROFILE%\chrome-kdp-profile"
#
# Then open Amazon KDP (kdp.amazon.com) in that browser window and log in.
# The app will reuse that session for all uploads and bookshelf scans.
CDP_ENDPOINT=http://localhost:9222

# ── Server port ───────────────────────────────────────────────────────────────
PORT=8080
